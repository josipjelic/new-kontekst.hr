PORT=3000
NODE_ENV=development
# Set to 1 behind a reverse proxy (DigitalOcean App Platform, nginx) for correct client IP / rate limits
# TRUST_PROXY=1
CORS_ORIGIN=http://localhost:5173

# SMTP (nodemailer) — required in production for POST /api/contact
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OpenRouter — AI questionnaire (ADR-003)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Slug on OpenRouter is claude-haiku-4.5 (dot), not 4-5
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Temporary verbose logs for POST /api/questionnaire (set to 0 before go-live)
# QUESTIONNAIRE_DEBUG_LOG=0
