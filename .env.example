# Kopiraj u `.env` u rootu repozitorija za docker-compose (`cp .env.example .env`).
# Ne commitaj stvarni `.env`.

# Ako su portovi zauzeti na hostu, postavi npr. BACKEND_PUBLISH_PORT=3001 ili FRONTEND_PUBLISH_PORT=5175
# i uskladi CORS_ORIGIN s URL-om Vite dev servera (npr. http://localhost:5175).
# BACKEND_PUBLISH_PORT=3000
# FRONTEND_PUBLISH_PORT=5173

# --- Backend (Express) ---
PORT=3000
NODE_ENV=development
# Origin frontenda u pregledniku (Vite dev na hostu)
CORS_ORIGIN=http://localhost:5173

# --- Frontend (Vite) ---
# Bazni URL Express API-ja (kontakt forma). Za produkciju postavi npr. https://api.kontekst.hr
VITE_API_URL=http://localhost:3000

# --- Frontend (Vite dev u Dockeru) ---
# Proxy `/api` -> backend servis u docker-compose mreži
API_PROXY_TARGET=http://backend:3000

# --- Produkcijska simulacija (docker-compose.prod.yml) ---
# Jedan origin za statiku + /api preko nginx-a (npr. http://localhost)
# CORS_ORIGIN=http://localhost
